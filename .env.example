# Databricks (primary LLM)
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DATABRICKS_MODEL=databricks-claude-sonnet-4-5

# Ollama fallback (optional — comment out to disable)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Database
DATABASE_URL=sqlite+aiosqlite:///./well.db

# Frame cadence (hours between new frames)
FRAME_INTERVAL_HOURS=6

# App base URL (used by starter agents)
WELL_BASE_URL=http://localhost:8000
